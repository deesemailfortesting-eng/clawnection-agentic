# Copy this file to .env.local for local Next.js development.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser at build time.

NEXT_PUBLIC_VAPI_API_KEY=your_vapi_api_key_here
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your_vapi_assistant_id_here

# Server-only secrets — do NOT prefix with NEXT_PUBLIC_.
# These live in .dev.vars (local) and as Cloudflare Worker secrets (prod).
# VAPI_WEBHOOK_SECRET=replace_me
