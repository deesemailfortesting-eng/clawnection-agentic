{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "clawnection-agentic",
  "compatibility_date": "2026-04-26",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "clawnection-agentic"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "SCORING_WEIGHTS": "{\"baseScore\":50,\"sharedInterestPoints\":6,\"sharedInterestMax\":18,\"sharedValuePoints\":8,\"sharedValueMax\":24,\"intentMatchBonus\":12,\"intentMismatchPenalty\":8,\"commStyleMatchBonus\":8,\"commStyleMismatchPenalty\":4,\"locationBonus\":6,\"ageFitBonus\":6,\"ageMismatchPenalty\":10,\"smokingDealbreaker\":18,\"generalDealbreaker\":12,\"latencyFastBonus\":3,\"latencySlowBonus\":3,\"inconsistentPenalty\":3}"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "clawnection-db",
      "database_id": "5bddf833-3d10-43d2-a18c-e443d04e79af"
    }
  ]
}
